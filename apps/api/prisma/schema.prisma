generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String         @id @default(cuid())
  email              String         @unique
  name               String
  onboardingComplete Boolean        @default(false)
  sessions           Session[]
  subscriptions      Subscription[]
  renewals           Renewal[]
  cancellations      Cancellation[]
  blocks             Block[]
  disputes           Dispute[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Subscription {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchant        String
  category        String
  amount          Decimal            @db.Decimal(10, 2)
  billingCycle    BillingCycle
  status          SubscriptionStatus @default(ACTIVE)
  riskLevel       RiskLevel          @default(LOW)
  nextRenewalDate DateTime?
  cancelMethod    CancellationMethod @default(IN_APP)
  cancellationUrl String
  startedAt       DateTime
  renewals        Renewal[]
  cancellations   Cancellation[]
  block           Block?
  disputes        Dispute[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([userId])
  @@index([status, riskLevel])
}

model Renewal {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId String
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  date           DateTime
  amount         Decimal       @db.Decimal(10, 2)
  status         RenewalStatus @default(CHARGED)
  note           String
  createdAt      DateTime      @default(now())

  @@index([userId])
  @@index([subscriptionId, date])
}

model Cancellation {
  id             String            @id @default(cuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId String
  subscription   Subscription      @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  state          CancellationState @default(NOT_STARTED)
  method         CancellationMethod
  requestedAt    DateTime
  completedAt    DateTime?
  nextAction     String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([userId])
  @@index([subscriptionId])
}

model Block {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId String       @unique
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  enabled        Boolean      @default(false)
  updatedAt      DateTime     @updatedAt
  createdAt      DateTime     @default(now())

  @@index([userId])
}

model Dispute {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId String
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  incidentDate   DateTime
  amount         Decimal       @db.Decimal(10, 2)
  reason         String
  status         DisputeStatus @default(DRAFT)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId])
  @@index([subscriptionId])
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELING
  CANCELLED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum RenewalStatus {
  CHARGED
  BLOCKED
  DISPUTED
}

enum CancellationState {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum CancellationMethod {
  IN_APP
  EMAIL
  PHONE
  CHAT
}

enum DisputeStatus {
  DRAFT
  SUBMITTED
  WON
  LOST
}
